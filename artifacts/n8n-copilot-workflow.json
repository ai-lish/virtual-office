      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "copilot-quota"
    },
    {
      "parameters": {
        "url": "http://localhost:18899/api/copilot/quota",
        "options": {
          "timeout": 10000
        }
      },
      "id": "http-get-quota",
      "name": "GET /api/copilot/quota",
