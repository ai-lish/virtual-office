      "typeVersion": 3,
      "position": [500, 500]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}"
      },
      "id": "respond-analysis",
      "name": "Respond with Analysis",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [750, 500]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "hours": 9,
              "minutes": 0,
              "dayInterval": 1
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Schedule Trigger (Daily 9am)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [250, 700]
    },
    {
      "parameters": {
        "url": "http://localhost:18899/api/copilot/quota",
        "options": {
          "timeout": 10000
        }
      },
      "id": "http-get-quota-scheduled",
      "name": "GET Quota (Scheduled)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [500, 700]
    },
    {
      "parameters": {
        "operation": "append",
        "sheetId": "YOUR_GOOGLE_SHEET_ID",
        "tableFormat": "detectAutomatically",
        "options": {
          "scope": "sheet"
        }
      },
      "id": "google-sheets-append",
      "name": "Append to Google Sheet",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 3.2,
      "position": [750, 700]
    },
    {
      "parameters": {
        "rule": {
          "field": "days",
          "hours": 9,
          "minutes": 30,
          "dayInterval": 1
        }
      },
      "id": "schedule-trigger-analysis",
      "name": "Schedule Trigger (Daily 9:30am)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [250, 900]
    },
    {
      "parameters": {
        "url": "http://localhost:18899/api/copilot/analysis",
        "options": {
          "timeout": 10000
        }
      },
      "id": "http-get-analysis-scheduled",
      "name": "GET Analysis (Scheduled)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [500, 900]
    },
    {
      "parameters": {
        "to": "YOUR_EMAIL@example.com",
        "subject": "Copilot Usage Report - {{ $json.data.quota.usedPercent }}% used",
        "body": "={{ JSON.stringify($json.data, null, 2) }}",
        "options": {}
      },
      "id": "email-notify",
      "name": "Email Notification",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 1.1,
      "position": [750, 900]
    }
